{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "exchanges": {
      ".read": "true",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
      },
      ".indexOn": ["country", "university", "study", "specialization", "numSemesters"]
    },

    "exchangesTest": {
      ".read": "true",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
      },
      ".indexOn": ["country", "university", "study", "specialization", "numSemesters"]
    },

    "faq": {
      ".read": "true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },

    "admins": {
      ".read": "auth != null",
      ".write": "root.child('admins').child(auth.uid).val() === true"
    },

    "uploads": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },

    "reports": {
      ".read": "true",
      ".indexOn": ["authorId", "university", "country", "status"],
      "$reportId": {
        ".write": "auth != null && ((!data.exists() && newData.child('authorId').val() === auth.uid) || (data.exists() && data.child('authorId').val() === auth.uid) || root.child('admins').child(auth.uid).val() === true)"
      }
    }
  }
}
